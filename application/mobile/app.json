{
  "expo": {
    "name": "SiteStack",
    "slug": "sitestack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C3A5E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitestack.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C3A5E"
      },
      "package": "com.sitestack.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-sqlite", { "enableFTS": true }]
    ],
    "scheme": "sitestack",
    "experiments": {
      "typedRoutes": true
    }
  }
}
